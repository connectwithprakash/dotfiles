#!/usr/bin/env bash
# Dotfiles CLI - Main entry point for managing dotfiles
#
# Usage:
#   dotfiles                # Launch interactive menu
#   dotfiles sync           # Sync dotfiles
#   dotfiles install        # Install components
#   dotfiles status         # Show status
#   dotfiles health         # Run health check
#   dotfiles help           # Show help

set -e

# Get the repository directory even when this CLI is invoked through a symlink
# such as ~/.local/bin/dotfiles. macOS readlink does not support -f, so resolve
# links manually.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" == /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$SOURCE_DIR/$TARGET"
  fi
done
DOTFILES_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
unset SOURCE SOURCE_DIR TARGET
# shellcheck source=scripts/managed_dotfiles.sh
source "$DOTFILES_DIR/scripts/managed_dotfiles.sh"

# Colors (used in print_* functions and inline output)
# shellcheck disable=SC2034
GREEN='\033[0;32m' BLUE='\033[0;34m' YELLOW='\033[1;33m'
RED='\033[0;31m' CYAN='\033[0;36m' GRAY='\033[0;90m' NC='\033[0m'

# Check if gum is available
HAS_GUM=false
if command -v gum &> /dev/null; then
  HAS_GUM=true
fi

# Helper functions
print_header() {
  if [ "$HAS_GUM" = true ]; then
    gum style \
      --border double \
      --border-foreground 212 \
      --padding "0 2" \
      --margin "1 0" \
      "$1"
  else
    echo ""
    echo -e "${BLUE}--- $1 ---${NC}"
    echo ""
  fi
}

print_success() { echo -e "${GREEN}[ok]${NC} $1"; }
print_error() { echo -e "${RED}[error]${NC} $1"; }
print_info() { echo -e "${CYAN}[info]${NC} $1"; }

# Show help
show_help() {
  print_header "Dotfiles Manager - Help"

  echo -e "${CYAN}Usage:${NC}"
  echo "  dotfiles [command]"
  echo ""
  echo -e "${CYAN}Commands:${NC}"
  echo -e "  ${GREEN}sync${NC}       Sync dotfiles interactively"
  echo -e "  ${GREEN}apply${NC}      Apply repo dotfiles to home non-interactively"
  echo -e "  ${GREEN}capture${NC}    Capture home dotfiles into repo non-interactively"
  echo -e "  ${GREEN}list${NC}       List managed dotfiles and live paths"
  echo -e "  ${GREEN}install${NC}    Install or update components"
  echo -e "  ${GREEN}update${NC}     Update all installed tools and plugins"
  echo -e "  ${GREEN}status${NC}     Show current status of dotfiles and components"
  echo -e "  ${GREEN}health${NC}     Run health check on installed components"
  echo -e "  ${GREEN}help${NC}       Show this help message"
  echo ""
  echo -e "${CYAN}Examples:${NC}"
  echo "  dotfiles              # Launch interactive menu"
  echo "  dotfiles sync         # Sync dotfiles interactively"
  echo "  dotfiles apply        # Apply all repo-managed dotfiles to home"
  echo "  dotfiles apply zsh/starship.toml"
  echo "  dotfiles capture .aliases"
  echo "  dotfiles install      # Install components interactively"
  echo "  dotfiles install zsh  # Install/apply only Zsh + Starship"
  echo "  dotfiles install --dry-run zsh iterm2"
  echo "  dotfiles status       # Show current status"
  echo "  dotfiles health       # Run health check"
}

# Resolve optional command arguments to managed dotfiles. With no arguments,
# operate on every managed file.
resolve_managed_targets() {
  resolved_targets=()

  if [ "$#" -eq 0 ]; then
    resolved_targets=("${managed_dotfiles[@]}")
    return 0
  fi

  local requested file matched
  for requested in "$@"; do
    matched=false
    for file in "${managed_dotfiles[@]}"; do
      if [ "$requested" = "$file" ] || [ "$requested" = "$(basename "$file")" ]; then
        resolved_targets+=("$file")
        matched=true
        break
      fi
    done
    if [ "$matched" = false ]; then
      print_error "Unknown managed dotfile: $requested"
      print_info "Run 'dotfiles list' to see valid names."
      return 1
    fi
  done
}

list_managed_dotfiles() {
  print_header "Managed Dotfiles"
  local file
  for file in "${managed_dotfiles[@]}"; do
    echo "$file -> $(get_home_path "$file")"
  done
}

backup_live_file() {
  local home_path="$1"
  [ -e "$home_path" ] || return 0

  local backup_dir
  backup_dir="$HOME/.dotfiles-backup/$(date +%Y-%m-%d_%H%M%S)"
  local relative_path="${home_path#"$HOME"/}"
  local backup_path="$backup_dir/$relative_path"
  mkdir -p "$(dirname "$backup_path")"
  cp "$home_path" "$backup_path"
}

apply_repo_to_home() {
  resolve_managed_targets "$@" || return 1
  local file repo_path home_path label changed=0 skipped=0

  for file in "${resolved_targets[@]}"; do
    repo_path="$DOTFILES_DIR/$file"
    home_path="$(get_home_path "$file")"
    label="$(get_dotfile_label "$file")"

    if [ ! -f "$repo_path" ]; then
      print_error "$label missing in repository"
      continue
    fi

    if [ -f "$home_path" ] && diff -q "$home_path" "$repo_path" >/dev/null 2>&1; then
      echo "No changes in $label (skipped)"
      skipped=$((skipped + 1))
      continue
    fi

    backup_live_file "$home_path"
    mkdir -p "$(dirname "$home_path")"
    cp "$repo_path" "$home_path"
    echo "Applied $label to $home_path"
    changed=$((changed + 1))
  done

  print_success "Applied $changed file(s); skipped $skipped unchanged file(s)."
}

capture_home_to_repo() {
  resolve_managed_targets "$@" || return 1
  local file repo_path home_path label changed=0 skipped=0

  for file in "${resolved_targets[@]}"; do
    repo_path="$DOTFILES_DIR/$file"
    home_path="$(get_home_path "$file")"
    label="$(get_dotfile_label "$file")"

    if [ ! -f "$home_path" ]; then
      print_error "$label missing at $home_path"
      continue
    fi

    if [ -f "$repo_path" ] && diff -q "$home_path" "$repo_path" >/dev/null 2>&1; then
      echo "No changes in $label (skipped)"
      skipped=$((skipped + 1))
      continue
    fi

    mkdir -p "$(dirname "$repo_path")"
    cp "$home_path" "$repo_path"
    echo "Captured $home_path to $label"
    changed=$((changed + 1))
  done

  print_success "Captured $changed file(s); skipped $skipped unchanged file(s)."
}

# Show status
show_status() {
  print_header "Dotfiles Status"

  echo -e "${CYAN}Installed Components:${NC}"

  # Zsh
  if command -v zsh &> /dev/null; then
    local zsh_ver
    zsh_ver=$(zsh --version | awk '{print $2}')
    print_success "Zsh $zsh_ver"
    [ -d "$HOME/.oh-my-zsh" ] && echo -e "  ${GRAY}-> Oh My Zsh installed${NC}"
  else
    echo -e "${GRAY}  - Zsh (not installed)${NC}"
  fi

  # Neovim
  if command -v nvim &> /dev/null; then
    local nvim_ver
    nvim_ver=$(nvim --version | head -n1 | awk '{print $2}')
    print_success "Neovim $nvim_ver"
  else
    echo -e "${GRAY}  - Neovim (not installed)${NC}"
  fi

  # VS Code
  if command -v code &> /dev/null; then
    local code_ver
    code_ver=$(code --version 2>/dev/null | head -n1 || echo "unknown")
    print_success "VS Code $code_ver"
  else
    echo -e "  ${GRAY}- VS Code (not installed)${NC}"
  fi

  # Claude Code
  if [ -f "$HOME/.claude/settings.json" ]; then
    print_success "Claude Code (configured)"
    local skill_count
    skill_count=$(find "$HOME/.claude/skills" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  ${GRAY}-> $skill_count skill(s) installed${NC}"
  else
    echo -e "${GRAY}  - Claude Code (not configured)${NC}"
  fi

  # TUI Tools
  echo ""
  echo -e "${CYAN}TUI Tools:${NC}"
  for tool in gum fzf; do
    if command -v "$tool" &> /dev/null; then
      print_success "$tool (installed)"
    else
      echo -e "${GRAY}  - $tool (not installed)${NC}"
    fi
  done

  # Sync status
  echo ""
  echo -e "${CYAN}Sync Status:${NC}"
  cd "$DOTFILES_DIR"
  if git status --porcelain 2>/dev/null | grep -q .; then
    print_info "Uncommitted changes in repository"
  else
    print_success "Repository is clean"
  fi

  local changed=0
  local missing=0
  local total=0

  for file in "${managed_dotfiles[@]}"; do
    local home_path
    local repo_path
    local label

    home_path="$(get_home_path "$file")"
    repo_path="$DOTFILES_DIR/$file"
    label="$(get_dotfile_label "$file")"
    total=$((total + 1))

    if [ ! -e "$home_path" ] || [ ! -e "$repo_path" ]; then
      missing=$((missing + 1))
      print_info "$label missing on one side"
    elif ! diff -q "$home_path" "$repo_path" >/dev/null 2>&1; then
      changed=$((changed + 1))
      print_info "$label differs"
    fi
  done

  if [ "$changed" -gt 0 ] || [ "$missing" -gt 0 ]; then
    print_info "$changed changed and $missing missing of $total managed dotfile(s)"
  else
    print_success "All $total managed dotfile(s) are synced"
  fi
}

# Health check
run_health_check() {
  print_header "System Health Check"

  local errors=0
  local warnings=0

  echo -e "${CYAN}Shell Configuration:${NC}"
  if [[ "$SHELL" == */zsh ]]; then
    print_success "Zsh is default shell"
  else
    print_info "Default shell: $SHELL (consider switching to Zsh)"
    ((warnings++))
  fi

  if [ -f "$HOME/.zshrc" ]; then print_success ".zshrc exists"; else print_error ".zshrc not found"; ((errors++)); fi

  echo ""
  echo -e "${CYAN}Development Tools:${NC}"
  for tool in git nvim code gum fzf fd jq tree rg starship zoxide pyenv uv ruff; do
    if command -v "$tool" &> /dev/null; then
      print_success "$tool installed"
    else
      print_info "$tool not installed (optional)"
      ((warnings++))
    fi
  done

  if command -v nvim &> /dev/null; then
    echo ""
    echo -e "${CYAN}Neovim Configuration:${NC}"
    if [ -f "$HOME/.config/nvim/init.lua" ]; then print_success "init.lua exists"; else print_info "init.lua not found"; ((warnings++)); fi
    if [ -d "$HOME/.local/share/nvim/lazy/lazy.nvim" ]; then print_success "lazy.nvim installed"; else print_info "lazy.nvim not installed"; ((warnings++)); fi
  fi

  echo ""
  echo -e "${CYAN}Prompt:${NC}"
  if command -v starship &> /dev/null; then
    print_success "Starship prompt installed"
    if [ -f "$HOME/.config/starship.toml" ]; then print_success "starship.toml exists"; else print_info "starship.toml not found"; ((warnings++)); fi
  else
    print_info "Starship not installed"
    ((warnings++))
  fi

  echo ""
  echo -e "${CYAN}Summary:${NC}"
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    print_success "All checks passed! System is healthy."
  elif [ "$errors" -eq 0 ]; then
    print_info "$warnings warning(s) found"
  else
    print_error "$errors error(s) and $warnings warning(s) found"
  fi
}

# Update installed tools
update_tools() {
  print_header "Updating Tools"

  if command -v brew &> /dev/null; then
    print_info "Updating Homebrew packages..."
    brew update && brew upgrade
  fi

  if command -v uv &> /dev/null; then
    print_info "Updating uv tools..."
    uv tool upgrade --all || true
  fi

  if command -v pyenv &> /dev/null; then
    print_info "Updating pyenv..."
    if command -v brew &> /dev/null; then
      brew upgrade pyenv || true
    else
      pyenv update || true
    fi
  fi

  if command -v nvim &> /dev/null && [ -d "$HOME/.local/share/nvim/lazy/lazy.nvim" ]; then
    print_info "Updating Neovim plugins..."
    nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
  fi

  local zsh_custom="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
  if [ -d "$zsh_custom/plugins" ]; then
    print_info "Updating Zsh plugins..."
    for plugin_dir in "$zsh_custom/plugins"/*/; do
      if [ -d "$plugin_dir/.git" ]; then
        local plugin_name
        plugin_name="$(basename "$plugin_dir")"
        if git -C "$plugin_dir" pull --quiet; then print_success "$plugin_name updated"; else print_warning "$plugin_name update failed"; fi
      fi
    done
  fi

  if [ -d "$HOME/.oh-my-zsh" ]; then
    print_info "Updating Oh My Zsh..."
    git -C "$HOME/.oh-my-zsh" pull --quiet || true
  fi

  print_success "All tools updated!"
}

# Main menu
show_menu() {
  if [ "$HAS_GUM" = true ]; then
    gum style \
      --border double \
      --border-foreground 212 \
      --padding "1 2" \
      --margin "1 0" \
      "Dotfiles Manager" \
      "" \
      "Manage your development environment"

    CHOICE=$(gum choose \
      "Sync Dotfiles" \
      "Install Components" \
      "Update Tools" \
      "Show Status" \
      "Run Health Check" \
      "Help" \
      "Exit")

    case "$CHOICE" in
      "Sync Dotfiles") "$DOTFILES_DIR/update_dotfiles.sh" ;;
      "Install Components") "$DOTFILES_DIR/bootstrap.sh" ;;
      "Update Tools") update_tools ;;
      "Show Status") show_status ;;
      "Run Health Check") run_health_check ;;
      "Help") show_help ;;
      "Exit") echo "Goodbye!"; exit 0 ;;
    esac
  else
    print_header "Dotfiles Manager"
    echo "1) Sync Dotfiles"
    echo "2) Install Components"
    echo "3) Update Tools"
    echo "4) Show Status"
    echo "5) Run Health Check"
    echo "6) Help"
    echo "7) Exit"
    echo ""
    read -rp "Choose an option (1-7): " choice

    case "$choice" in
      1) "$DOTFILES_DIR/update_dotfiles.sh" ;;
      2) "$DOTFILES_DIR/bootstrap.sh" ;;
      3) update_tools ;;
      4) show_status ;;
      5) run_health_check ;;
      6) show_help ;;
      7) echo "Goodbye!"; exit 0 ;;
      *) echo "Invalid option"; exit 1 ;;
    esac
  fi
}

# Main command router
cd "$DOTFILES_DIR"

case "${1:-menu}" in
  sync)
    shift
    "$DOTFILES_DIR/update_dotfiles.sh" "$@"
    ;;
  apply)
    shift
    apply_repo_to_home "$@"
    ;;
  capture)
    shift
    capture_home_to_repo "$@"
    ;;
  list)
    list_managed_dotfiles
    ;;
  install)
    shift
    "$DOTFILES_DIR/bootstrap.sh" "$@"
    ;;
  status)
    show_status
    ;;
  health)
    run_health_check
    ;;
  update)
    update_tools
    ;;
  help|--help|-h)
    show_help
    ;;
  menu|"")
    show_menu
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo "Run 'dotfiles help' for usage information"
    exit 1
    ;;
esac
