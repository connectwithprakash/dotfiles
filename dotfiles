#!/usr/bin/env bash
# Dotfiles CLI - Main entry point for managing dotfiles
#
# Usage:
#   dotfiles                # Launch interactive menu
#   dotfiles sync           # Sync dotfiles
#   dotfiles install        # Install components
#   dotfiles status         # Show status
#   dotfiles health         # Run health check
#   dotfiles help           # Show help

set -e

# Get the directory where this script is located
DOTFILES_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
GRAY='\033[0;90m'
NC='\033[0m'

# Check if gum is available
HAS_GUM=false
if command -v gum &> /dev/null; then
  HAS_GUM=true
fi

# Helper functions
print_header() {
  if [ "$HAS_GUM" = true ]; then
    gum style \
      --border double \
      --border-foreground 212 \
      --padding "0 2" \
      --margin "1 0" \
      "$1"
  else
    echo ""
    echo -e "${BLUE}--- $1 ---${NC}"
    echo ""
  fi
}

print_success() { echo -e "${GREEN}[ok]${NC} $1"; }
print_error() { echo -e "${RED}[error]${NC} $1"; }
print_info() { echo -e "${CYAN}[info]${NC} $1"; }

# Show help
show_help() {
  print_header "Dotfiles Manager - Help"

  echo -e "${CYAN}Usage:${NC}"
  echo "  dotfiles [command]"
  echo ""
  echo -e "${CYAN}Commands:${NC}"
  echo -e "  ${GREEN}sync${NC}       Sync dotfiles between home directory and repository"
  echo -e "  ${GREEN}install${NC}    Install or update components"
  echo -e "  ${GREEN}update${NC}     Update all installed tools and plugins"
  echo -e "  ${GREEN}status${NC}     Show current status of dotfiles and components"
  echo -e "  ${GREEN}health${NC}     Run health check on installed components"
  echo -e "  ${GREEN}help${NC}       Show this help message"
  echo ""
  echo -e "${CYAN}Examples:${NC}"
  echo "  dotfiles              # Launch interactive menu"
  echo "  dotfiles sync         # Sync dotfiles interactively"
  echo "  dotfiles install      # Install components interactively"
  echo "  dotfiles status       # Show current status"
  echo "  dotfiles health       # Run health check"
}

# Show status
show_status() {
  print_header "Dotfiles Status"

  echo -e "${CYAN}Installed Components:${NC}"

  # Zsh
  if command -v zsh &> /dev/null; then
    local zsh_ver
    zsh_ver=$(zsh --version | awk '{print $2}')
    print_success "Zsh $zsh_ver"
    [ -d "$HOME/.oh-my-zsh" ] && echo -e "  ${GRAY}-> Oh My Zsh installed${NC}"
  else
    echo -e "${GRAY}  - Zsh (not installed)${NC}"
  fi

  # Neovim
  if command -v nvim &> /dev/null; then
    local nvim_ver
    nvim_ver=$(nvim --version | head -n1 | awk '{print $2}')
    print_success "Neovim $nvim_ver"
  else
    echo -e "${GRAY}  - Neovim (not installed)${NC}"
  fi

  # VS Code
  if command -v code &> /dev/null; then
    local code_ver
    code_ver=$(code --version 2>/dev/null | head -n1 || echo "unknown")
    print_success "VS Code $code_ver"
  else
    echo -e "  ${GRAY}- VS Code (not installed)${NC}"
  fi

  # Claude Code
  if [ -f "$HOME/.claude/settings.json" ]; then
    print_success "Claude Code (configured)"
    local skill_count
    skill_count=$(find "$HOME/.claude/skills" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo -e "  ${GRAY}-> $skill_count skill(s) installed${NC}"
  else
    echo -e "${GRAY}  - Claude Code (not configured)${NC}"
  fi

  # TUI Tools
  echo ""
  echo -e "${CYAN}TUI Tools:${NC}"
  for tool in gum fzf; do
    if command -v "$tool" &> /dev/null; then
      print_success "$tool (installed)"
    else
      echo -e "${GRAY}  - $tool (not installed)${NC}"
    fi
  done

  # Sync status
  echo ""
  echo -e "${CYAN}Sync Status:${NC}"
  cd "$DOTFILES_DIR"
  if git status --porcelain 2>/dev/null | grep -q .; then
    print_info "Uncommitted changes in repository"
  else
    print_success "Repository is clean"
  fi

  local changed=0
  if [ -f "$HOME/.zshrc" ] && [ -f "$DOTFILES_DIR/zsh/.zshrc" ]; then
    if ! diff -q "$HOME/.zshrc" "$DOTFILES_DIR/zsh/.zshrc" &>/dev/null; then
      ((changed++))
    fi
  fi

  if [ "$changed" -gt 0 ]; then
    print_info "$changed dotfile(s) have unsync'd changes"
  else
    print_success "All dotfiles are synced"
  fi
}

# Health check
run_health_check() {
  print_header "System Health Check"

  local errors=0
  local warnings=0

  echo -e "${CYAN}Shell Configuration:${NC}"
  if [[ "$SHELL" == */zsh ]]; then
    print_success "Zsh is default shell"
  else
    print_info "Default shell: $SHELL (consider switching to Zsh)"
    ((warnings++))
  fi

  [ -f "$HOME/.zshrc" ] && print_success ".zshrc exists" || { print_error ".zshrc not found"; ((errors++)); }

  echo ""
  echo -e "${CYAN}Development Tools:${NC}"
  for tool in git nvim code gum fzf fd jq tree rg starship zoxide pyenv uv ruff; do
    if command -v "$tool" &> /dev/null; then
      print_success "$tool installed"
    else
      print_info "$tool not installed (optional)"
      ((warnings++))
    fi
  done

  if command -v nvim &> /dev/null; then
    echo ""
    echo -e "${CYAN}Neovim Configuration:${NC}"
    [ -f "$HOME/.config/nvim/init.lua" ] && print_success "init.lua exists" || { print_info "init.lua not found"; ((warnings++)); }
    [ -d "$HOME/.local/share/nvim/lazy/lazy.nvim" ] && print_success "lazy.nvim installed" || { print_info "lazy.nvim not installed"; ((warnings++)); }
  fi

  echo ""
  echo -e "${CYAN}Prompt:${NC}"
  if command -v starship &> /dev/null; then
    print_success "Starship prompt installed"
    [ -f "$HOME/.config/starship.toml" ] && print_success "starship.toml exists" || { print_info "starship.toml not found"; ((warnings++)); }
  else
    print_info "Starship not installed"
    ((warnings++))
  fi

  echo ""
  echo -e "${CYAN}Summary:${NC}"
  if [ "$errors" -eq 0 ] && [ "$warnings" -eq 0 ]; then
    print_success "All checks passed! System is healthy."
  elif [ "$errors" -eq 0 ]; then
    print_info "$warnings warning(s) found"
  else
    print_error "$errors error(s) and $warnings warning(s) found"
  fi
}

# Update installed tools
update_tools() {
  print_header "Updating Tools"

  if command -v brew &> /dev/null; then
    print_info "Updating Homebrew packages..."
    brew update && brew upgrade
  fi

  if command -v uv &> /dev/null; then
    print_info "Updating uv tools..."
    uv tool upgrade --all || true
  fi

  if command -v pyenv &> /dev/null; then
    print_info "Updating pyenv..."
    if command -v brew &> /dev/null; then
      brew upgrade pyenv || true
    else
      pyenv update || true
    fi
  fi

  if command -v nvim &> /dev/null && [ -d "$HOME/.local/share/nvim/lazy/lazy.nvim" ]; then
    print_info "Updating Neovim plugins..."
    nvim --headless "+Lazy! sync" +qa 2>/dev/null || true
  fi

  local zsh_custom="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
  if [ -d "$zsh_custom/plugins" ]; then
    print_info "Updating Zsh plugins..."
    for plugin_dir in "$zsh_custom/plugins"/*/; do
      if [ -d "$plugin_dir/.git" ]; then
        local plugin_name
        plugin_name="$(basename "$plugin_dir")"
        git -C "$plugin_dir" pull --quiet && print_success "$plugin_name updated" || print_warning "$plugin_name update failed"
      fi
    done
  fi

  if [ -d "$HOME/.oh-my-zsh" ]; then
    print_info "Updating Oh My Zsh..."
    git -C "$HOME/.oh-my-zsh" pull --quiet || true
  fi

  print_success "All tools updated!"
}

# Main menu
show_menu() {
  if [ "$HAS_GUM" = true ]; then
    gum style \
      --border double \
      --border-foreground 212 \
      --padding "1 2" \
      --margin "1 0" \
      "Dotfiles Manager" \
      "" \
      "Manage your development environment"

    CHOICE=$(gum choose \
      "Sync Dotfiles" \
      "Install Components" \
      "Update Tools" \
      "Show Status" \
      "Run Health Check" \
      "Help" \
      "Exit")

    case "$CHOICE" in
      "Sync Dotfiles") "$DOTFILES_DIR/update_dotfiles.sh" ;;
      "Install Components") "$DOTFILES_DIR/bootstrap.sh" ;;
      "Update Tools") update_tools ;;
      "Show Status") show_status ;;
      "Run Health Check") run_health_check ;;
      "Help") show_help ;;
      "Exit") echo "Goodbye!"; exit 0 ;;
    esac
  else
    print_header "Dotfiles Manager"
    echo "1) Sync Dotfiles"
    echo "2) Install Components"
    echo "3) Update Tools"
    echo "4) Show Status"
    echo "5) Run Health Check"
    echo "6) Help"
    echo "7) Exit"
    echo ""
    read -p "Choose an option (1-7): " choice

    case "$choice" in
      1) "$DOTFILES_DIR/update_dotfiles.sh" ;;
      2) "$DOTFILES_DIR/bootstrap.sh" ;;
      3) update_tools ;;
      4) show_status ;;
      5) run_health_check ;;
      6) show_help ;;
      7) echo "Goodbye!"; exit 0 ;;
      *) echo "Invalid option"; exit 1 ;;
    esac
  fi
}

# Main command router
cd "$DOTFILES_DIR"

case "${1:-menu}" in
  sync)
    shift
    "$DOTFILES_DIR/update_dotfiles.sh" "$@"
    ;;
  install)
    shift
    "$DOTFILES_DIR/bootstrap.sh" "$@"
    ;;
  status)
    show_status
    ;;
  health)
    run_health_check
    ;;
  update)
    update_tools
    ;;
  help|--help|-h)
    show_help
    ;;
  menu|"")
    show_menu
    ;;
  *)
    echo -e "${RED}Unknown command: $1${NC}"
    echo "Run 'dotfiles help' for usage information"
    exit 1
    ;;
esac
