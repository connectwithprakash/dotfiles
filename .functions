#!/usr/bin/env bash

# Create a new directory and enter it
mkd() {
  mkdir -p "$@" && cd "$_" || return
}

# Create a .tar.gz archive, using `zopfli`, `pigz` or `gzip` for compression
targz() {
  local tmpFile="${*%/}.tar"
  tar -cvf "${tmpFile}" --exclude=".DS_Store" "${@}" || return 1

  size=$(stat -f"%z" "${tmpFile}" 2>/dev/null || stat -c"%s" "${tmpFile}" 2>/dev/null)

  local cmd=""
  if ((size < 52428800)) && hash zopfli 2>/dev/null; then
    cmd="zopfli"
  elif hash pigz 2>/dev/null; then
    cmd="pigz"
  else
    cmd="gzip"
  fi

  echo "Compressing .tar ($((size / 1000)) kB) using \`${cmd}\`..."
  "${cmd}" -v "${tmpFile}" || return 1
  [ -f "${tmpFile}" ] && rm "${tmpFile}"
  echo "${tmpFile}.gz created successfully."
}

# Determine size of a file or total size of a directory
fs() {
  if du -b /dev/null >/dev/null 2>&1; then
    local arg=-sbh
  else
    local arg=-sh
  fi
  if [[ -n "$*" ]]; then
    du "$arg" -- "$@"
  else
    du "$arg" .[^.]* ./*
  fi
}

# Use Git's colored diff when available
diff() {
  if hash git 2>/dev/null; then
    git diff --no-index --color-words "$@"
  else
    command diff "$@"
  fi
}

# Create a data URL from a file
dataurl() {
  local mimeType
  mimeType=$(file -b --mime-type "$1")
  if [[ $mimeType == text/* ]]; then
    mimeType="${mimeType};charset=utf-8"
  fi
  echo "data:${mimeType};base64,$(openssl base64 -in "$1" | tr -d '\n')"
}

# Start an HTTP server from a directory, optionally specifying the port
server() {
  local port="${1:-8000}"
  open "http://localhost:${port}/"
  python3 -m http.server "$port"
}

# Compare original and gzipped file size
gz() {
  local origsize
  origsize=$(wc -c <"$1")
  local gzipsize
  gzipsize=$(gzip -c "$1" | wc -c)
  local ratio
  ratio=$(echo "$gzipsize * 100 / $origsize" | bc -l)
  printf "orig: %d bytes\n" "$origsize"
  printf "gzip: %d bytes (%2.2f%%)\n" "$gzipsize" "$ratio"
}

# Run `dig` and display the most useful info
digga() {
  dig +nocmd "$1" any +multiline +noall +answer
}

# `tre` is a shorthand for `tree` with hidden files and color enabled, ignoring
# common directories, listing directories first.
tre() {
  tree -aC -I '.git|node_modules|.venv|__pycache__' --dirsfirst "$@" | less -FRNX
}

# Enter the local Tinker cookbook environment
tinkerenv() {
  cd "$HOME/Developer/tinker-cookbook" || return
  source "$HOME/venvs/tinker311/.venv/bin/activate"
  set -a
  source "$HOME/.hermes/.env"
  set +a
}

# Launch the Hello Tinker tutorial
tinkerhello() {
  tinkerenv || return
  ./run_hello_tinker.sh
}

# Launch the first SFT tutorial
tinkersft() {
  tinkerenv || return
  ./run_first_sft_tutorial.sh
}

# Show quick status for the local Tinker setup
tinkerstatus() {
  tinkerenv || return
  python - <<'PY'
import os
import tinker, marimo, tinker_cookbook
print(f"cwd: {os.getcwd()}")
print(f"python: {os.sys.version.split()[0]}")
print(f"tinker: {getattr(tinker, '__version__', 'unknown')}")
print(f"marimo: {getattr(marimo, '__version__', 'unknown')}")
print(f"TINKER_API_KEY present: {bool(os.environ.get('TINKER_API_KEY'))}")
PY
}

# List Tinker training runs
tinkerruns() {
  tinkerenv || return
  tinker run list
}

# Launch the first RL tutorial
tinkerrl() {
  tinkerenv || return
  ./run_first_rl_tutorial.sh
}

# End-to-end health check for the local Tinker setup
tinkerdoctor() {
  tinkerenv || return
  python - <<'PY'
import os
from pathlib import Path
import tinker, marimo, tinker_cookbook
root = Path.home() / 'Developer' / 'tinker-cookbook'
print(f"cwd: {os.getcwd()}")
print(f"python: {os.sys.version.split()[0]}")
print(f"tinker: {getattr(tinker, '__version__', 'unknown')}")
print(f"marimo: {getattr(marimo, '__version__', 'unknown')}")
print(f"repo exists: {root.exists()}")
print(f"hello notebook: {(root / 'tutorials/101_hello_tinker.py').exists()}")
print(f"sft notebook: {(root / 'tutorials/102_first_sft.py').exists()}")
print(f"rl notebook: {(root / 'tutorials/104_first_rl.py').exists()}")
print(f"TINKER_API_KEY present: {bool(os.environ.get('TINKER_API_KEY'))}")
PY
  printf '\n--- tinker run list ---\n'
  tinker run list
}
